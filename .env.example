# ============================================================
# LiveKit Server
# Must match the values embedded in config/livekit.yaml.
# ============================================================
LIVEKIT_API_KEY=APIvoiceapp123
LIVEKIT_API_SECRET=super-secret-change-me-please-32bytes!!

# Public URL clients use to reach the LiveKit SFU.
# Local dev (plain ws):     ws://localhost:7880
# Production (TLS-terminated reverse proxy): wss://voice.example.com
LIVEKIT_HOST=ws://localhost:7880

# ============================================================
# coturn (TURN/STUN relay)
# ============================================================
TURN_DOMAIN=localhost
TURN_LISTEN_PORT=3478
TURN_TLS_PORT=5349
TURN_STATIC_SECRET=turn-shared-static-secret-change-me

# ============================================================
# Go backend service
# ============================================================
GO_HTTP_ADDR=:8080
# Public base URL of the Go API (used by the desktop client).
GO_PUBLIC_URL=http://localhost:8080
# SQLite database path (inside the container volume).
DB_PATH=/var/lib/voiceapp/app.db

# Optional CORS allow-list (comma separated origins, * to allow all).
CORS_ORIGINS=tauri://localhost,http://localhost:1420
