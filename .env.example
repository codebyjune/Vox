# ============================================================
# LiveKit credentials
# Get these from https://cloud.livekit.io (Projects → your project → Keys)
# API Secret is shown only when you generate it; copy it once.
# ============================================================
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=replace-with-your-livekit-api-secret

# Public URL of your LiveKit deployment.
# LiveKit Cloud free tier:    wss://your-project.livekit.cloud
# Self-hosted (your server):  wss://livekit.your-domain.com
LIVEKIT_HOST=wss://your-project.livekit.cloud

# ============================================================
# Go backend service (optional settings)
# ============================================================
GO_HTTP_ADDR=:8080

# SQLite file path for room/participant history. Relative paths are resolved
# against the working directory of the voiceapp process.
DB_PATH=./vox.db

# CORS allow-list (comma separated origins, * to allow all).
# Tauri packaged app does NOT send Origin, so "*" is fine.
CORS_ORIGINS=*
